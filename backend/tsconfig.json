{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,

    // "allowJs": true,
    // "checkJs": false,

    "esModuleInterop": true,

    "skipLibCheck": true,

    "forceConsistentCasingInFileNames": true,

    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",

    "resolveJsonModule": true
  },

  "include": ["src/**/*"],

  "exclude": [
    "node_modules",
    "dist"
  ]
}